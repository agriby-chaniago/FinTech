APP_NAME="Investment Planner Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8003

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fingoals
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

INVESTMENT_PLANNER_API_KEY=change-me
LOGOUT_SYNC_TIMEOUT=5
FINTRACK_LOGOUT_SYNC_URL=http://127.0.0.1:8001/api/internal/auth/logout-sync
FINTRACK_LOGOUT_SYNC_API_KEY=
FINLYZER_LOGOUT_SYNC_URL=http://127.0.0.1:8002/api/internal/auth/logout-sync
FINLYZER_LOGOUT_SYNC_API_KEY=
FINGOALS_LOGOUT_SYNC_URL=http://127.0.0.1:8003/api/internal/auth/logout-sync
FINGOALS_LOGOUT_SYNC_API_KEY=
SERVICE1_CALLBACK_ENABLED=false
SERVICE1_CALLBACK_URL=http://127.0.0.1:8001/api/service3/plans/callback
SERVICE1_CALLBACK_API_KEY=
SERVICE1_CALLBACK_TIMEOUT=10
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

AUTH_MODE=oidc
KEYCLOAK_ENABLED=true
KEYCLOAK_BASE_URL=http://127.0.0.1:8080
KEYCLOAK_REALM=fintech
KEYCLOAK_ISSUER=
KEYCLOAK_CLIENT_ID=fingoals-web
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=http://127.0.0.1:8003/auth/oidc/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://127.0.0.1:8003
KEYCLOAK_SCOPES="openid profile email"
KEYCLOAK_HTTP_TIMEOUT=10
KEYCLOAK_AUTHORIZATION_ENDPOINT=
KEYCLOAK_TOKEN_ENDPOINT=
KEYCLOAK_USERINFO_ENDPOINT=
KEYCLOAK_LOGOUT_ENDPOINT=
KEYCLOAK_JWKS_ENDPOINT=

SERVICE_B_ANALYZER_BASE_URL=http://127.0.0.1:8002
SERVICE_B_ANALYZER_LATEST_PATH=/api/user/analyze/auto/latest
SERVICE_B_ANALYZER_TIMEOUT=10

VITE_APP_NAME="${APP_NAME}"
